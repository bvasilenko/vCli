{
  "name": "@booga/vcli",
  "version": "0.1.3",
  "description": "Component scaffolding CLI. init project, add from registry, build with vSsg, check with vLint.",
  "type": "module",
  "bin": {
    "booga": "./dist/cli.js",
    "vcli": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/",
    "demo-dist/"
  ],
  "scripts": {
    "build": "tsup && node scripts/copy-templates.mjs && node scripts/build-demo-dist.mjs",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "shape-history": "bun run scripts/history-shape/index.ts"
  },
  "dependencies": {
    "@booga/vlint": "^0.1.0",
    "@booga/vregistry": "^0.1.0",
    "@booga/vssg": "^0.1.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^8.0.1",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5",
    "open": "^10.1.0",
    "ora": "^7.0.1",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.14.2",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.4.5",
    "tsup": "^8.1.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
